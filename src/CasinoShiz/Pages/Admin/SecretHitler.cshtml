@page "/admin/sh"
@model CasinoShiz.Pages.Admin.SecretHitlerModel
@{
    ViewData["Title"] = "Secret Hitler — CasinoShiz Admin";
}

<h1>Secret Hitler rooms</h1>
<p><a href="/admin">&larr; Back to users</a></p>

@if (Model.Rooms.Count == 0)
{
    <p class="muted">No open rooms right now.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Code</th>
                <th>Status</th>
                <th>Phase</th>
                <th>Players</th>
                <th>Pot</th>
                <th>Policies (L/F)</th>
                <th>Host</th>
                <th>Last action</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in Model.Rooms)
        {
            <tr>
                <td><a href="/admin/sh/@r.InviteCode"><code>@r.InviteCode</code></a></td>
                <td><span class="pill">@r.Status</span></td>
                <td>@r.Phase</td>
                <td>@r.PlayerCount</td>
                <td>@r.Pot (<span class="muted">@r.BuyIn buy-in</span>)</td>
                <td>🟦 @r.LiberalPolicies / 🟥 @r.FascistPolicies</td>
                <td><a href="/admin/user/@r.HostUserId">@r.HostUserId</a></td>
                <td class="muted">@DateTimeOffset.FromUnixTimeMilliseconds(r.LastActionAt).UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>
                    <form method="post" action="/admin/sh/@r.InviteCode/cancel" style="display:inline;"
                          onsubmit="return confirm('Cancel room @r.InviteCode and refund @r.BuyIn to all @r.PlayerCount players?');">
                        @Html.AntiForgeryToken()
                        <button type="submit">Cancel & refund</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
