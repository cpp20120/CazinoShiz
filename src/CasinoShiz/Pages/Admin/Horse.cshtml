@page "/admin/horse"
@model CasinoShiz.Pages.Admin.HorseModel
@{
    ViewData["Title"] = "Horse race — CasinoShiz Admin";
    var view = Model.View;
    var canRun = view != null && view.BetsCount >= view.MinBetsToRun;
}

<h1>Horse race</h1>
<p><a href="/admin">&larr; Back to users</a></p>

@if (view != null)
{
    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Race @view.RaceDate</h2>
        <div class="row" style="gap:24px; flex-wrap:wrap;">
            <div><span class="muted">Bets placed</span><br/><strong>@view.BetsCount</strong> / @view.MinBetsToRun min</div>
            <div><span class="muted">Total pot</span><br/><strong>@view.Stakes.Values.Sum()</strong></div>
        </div>

        <table style="margin-top:12px;">
            <thead><tr><th>Horse</th><th>Pot</th><th>Koef</th></tr></thead>
            <tbody>
            @for (var i = 0; i < view.Stakes.Count; i++)
            {
                <tr>
                    <td>@(i + 1)</td>
                    <td>@view.Stakes[i]</td>
                    <td>@(view.Koefs.TryGetValue(i, out var k) ? k.ToString("0.000") : "—")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="card">
        <form method="post" asp-page-handler="Run">
            @Html.AntiForgeryToken()
            <button type="submit" disabled="@(!canRun)">
                @(canRun ? "Run race" : $"Need {view.MinBetsToRun - view.BetsCount} more bet(s)")
            </button>
        </form>
    </div>
}

@if (Model.LastRun is { } run)
{
    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Last race result</h2>
        @if (run.Error == CasinoShiz.Services.Horse.HorseError.NotEnoughBets)
        {
            <p>Not enough bets to run (need @(Model.View?.MinBetsToRun ?? 0)).</p>
        }
        else
        {
            <p>Winner: <strong>horse @(run.Winner + 1)</strong>. Broadcast to channel: <strong>@(run.BroadcastedToChannel ? "yes" : "no")</strong>.</p>
            @if (!string.IsNullOrEmpty(Model.GifDataUrl))
            {
                <img src="@Model.GifDataUrl" alt="Race GIF" style="max-width:100%; border:1px solid #333;" />
            }
            @if (run.Winners.Count > 0)
            {
                <table style="margin-top:12px;">
                    <thead><tr><th>User ID</th><th>Payout</th></tr></thead>
                    <tbody>
                    @foreach (var w in run.Winners)
                    {
                        <tr><td>@w.UserId</td><td>+@w.Amount</td></tr>
                    }
                    </tbody>
                </table>
            }
            else
            {
                <p>No winners this race.</p>
            }
        }
    </div>
}
