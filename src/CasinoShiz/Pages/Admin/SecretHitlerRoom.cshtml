@page "/admin/sh/{code}"
@model CasinoShiz.Pages.Admin.SecretHitlerRoomModel
@{
    ViewData["Title"] = Model.View == null ? "Room not found" : $"SH room {Model.View.Game.InviteCode} — CasinoShiz Admin";
}

<p><a href="/admin/sh">&larr; Back to rooms</a></p>

@if (Model.View == null)
{
    <h1>Room not found</h1>
    <p class="muted">No Secret Hitler room with code <code>@Model.Code</code>.</p>
}
else
{
    var g = Model.View.Game;

    <h1>Room <code>@g.InviteCode</code> <span class="muted">@g.Status / @g.Phase</span></h1>

    <div class="card">
        <div class="row" style="gap:24px; flex-wrap:wrap;">
            <div><span class="muted">Host</span><br/><a href="/admin/user/@g.HostUserId">@g.HostUserId</a></div>
            <div><span class="muted">Buy-in</span><br/><strong>@g.BuyIn</strong></div>
            <div><span class="muted">Pot</span><br/><strong>@g.Pot</strong></div>
            <div><span class="muted">Liberal policies</span><br/><strong>@g.LiberalPolicies</strong> / 5</div>
            <div><span class="muted">Fascist policies</span><br/><strong>@g.FascistPolicies</strong> / 6</div>
            <div><span class="muted">Election tracker</span><br/><strong>@g.ElectionTracker</strong> / 3</div>
        </div>
        <p class="muted" style="margin-top:8px;">
            Created @DateTimeOffset.FromUnixTimeMilliseconds(g.CreatedAt).UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss") UTC ·
            last action @DateTimeOffset.FromUnixTimeMilliseconds(g.LastActionAt).UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss") UTC
        </p>
    </div>

    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Players</h2>
        <table>
            <thead>
                <tr>
                    <th>Pos</th>
                    <th>User</th>
                    <th>Role</th>
                    <th>Alive</th>
                    <th>Last vote</th>
                    <th>Chat</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in Model.View.Players)
            {
                var marker = p.Position == g.CurrentPresidentPosition ? "👑 "
                    : p.Position == g.NominatedChancellorPosition ? "🎩 "
                    : "";
                <tr>
                    <td>@marker#@p.Position</td>
                    <td><a href="/admin/user/@p.UserId">@p.DisplayName</a> <span class="muted">(@p.UserId)</span></td>
                    <td>@p.Role</td>
                    <td>@(p.IsAlive ? "yes" : "no")</td>
                    <td>@p.LastVote</td>
                    <td class="muted">@p.ChatId</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (g.Status == CasinoShiz.Data.Entities.ShStatus.Lobby || g.Status == CasinoShiz.Data.Entities.ShStatus.Active)
    {
        <div class="card">
            <h2 style="margin-top:0; font-size:16px;">Danger zone</h2>
            <form method="post" action="/admin/sh/@g.InviteCode/cancel"
                  onsubmit="return confirm('Close room and refund @g.BuyIn to each of @Model.View.Players.Count players?');">
                @Html.AntiForgeryToken()
                <button type="submit">Cancel room & refund all players</button>
            </form>
        </div>
    }
}
