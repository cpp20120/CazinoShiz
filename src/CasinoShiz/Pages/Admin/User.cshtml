@page "/admin/user/{id:long}"
@model CasinoShiz.Pages.Admin.UserDetailModel
@{
    ViewData["Title"] = Model.Detail == null ? "User not found" : $"{Model.Detail.User.DisplayName} — CasinoShiz Admin";
}

<p><a href="/admin">← Back to users</a></p>

@if (Model.Detail == null)
{
    <h1>User not found</h1>
    <p class="muted">No user with id <code>@Model.Id</code>.</p>
}
else
{
    var u = Model.Detail.User;

    <h1>@u.DisplayName <span class="muted">#@u.TelegramUserId</span></h1>

    <div class="card">
        <partial name="_UserStats" model="u" />
    </div>

    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Adjust coins</h2>
        <form class="row" hx-post="/admin/user/@u.TelegramUserId/pay" hx-target="#user-stats" hx-swap="outerHTML">
            @Html.AntiForgeryToken()
            <input type="number" name="amount" value="0" step="1" required style="width: 140px;" />
            <button type="submit">Pay / Charge</button>
            <span class="muted">Positive adds coins, negative deducts.</span>
        </form>
    </div>

    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Rename display name</h2>
        <form class="row" hx-post="/admin/user/@u.TelegramUserId/rename" hx-target="#rename-result" hx-swap="innerHTML">
            @Html.AntiForgeryToken()
            <input type="text" name="newName" placeholder="New name (or * to clear)" required style="flex:1; min-width:200px;" />
            <button type="submit">Rename</button>
        </form>
        <div id="rename-result" class="muted" style="margin-top:8px;">Applies on next <code>/run usersync</code>.</div>
    </div>

    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Recent horse bets</h2>
        @if (Model.Detail.RecentBets.Count == 0)
        {
            <p class="muted">No bets.</p>
        }
        else
        {
            <table>
                <thead><tr><th>Race date</th><th>Horse</th><th>Amount</th></tr></thead>
                <tbody>
                @foreach (var b in Model.Detail.RecentBets)
                {
                    <tr><td>@b.RaceDate</td><td>#@b.HorseId</td><td>@b.Amount</td></tr>
                }
                </tbody>
            </table>
        }
    </div>

    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Issued freespin codes</h2>
        @if (Model.Detail.IssuedCodes.Count == 0)
        {
            <p class="muted">No codes issued.</p>
        }
        else
        {
            <table>
                <thead><tr><th>Code</th><th>Active</th><th>Issued at</th></tr></thead>
                <tbody>
                @foreach (var c in Model.Detail.IssuedCodes)
                {
                    <tr>
                        <td><code>@c.Code</code></td>
                        <td>@(c.Active ? "yes" : "no")</td>
                        <td class="muted">@c.IssuedAt</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>

    @if (Model.Detail.PokerSeat is { } seat)
    {
        <div class="card">
            <h2 style="margin-top:0; font-size:16px;">Poker seat</h2>
            <p>Table <code>@seat.InviteCode</code> · seat @seat.Position · stack @seat.Stack · <span class="pill">@seat.Status</span></p>
            <form method="post" action="/admin/user/@u.TelegramUserId/poker/kick"
                  onsubmit="return confirm('Force leave table and refund stack of @seat.Stack coins?');">
                @Html.AntiForgeryToken()
                <button type="submit">Force leave (refund @seat.Stack)</button>
            </form>
        </div>
    }

    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Slot attempts (today)</h2>
        <p>Used: <strong>@u.AttemptCount</strong> · Extra: <strong>@u.ExtraAttempts</strong></p>
        @if (u.AttemptCount > 0 || u.ExtraAttempts > 0)
        {
            <form method="post" action="/admin/user/@u.TelegramUserId/attempts/reset"
                  onsubmit="return confirm('Reset slot attempts to 0?');">
                @Html.AntiForgeryToken()
                <button type="submit">Reset attempts</button>
            </form>
        }
        else
        {
            <p class="muted">Nothing to reset.</p>
        }
    </div>

    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Dice cube 🎲</h2>
        @if (Model.Detail.DiceCubeBet is { } cube)
        {
            <p>Pending bet: <strong>@cube.Amount</strong> in chat <code>@cube.ChatId</code></p>
            <form method="post" action="/admin/user/@u.TelegramUserId/dicecube/cancel"
                  onsubmit="return confirm('Refund @cube.Amount and drop pending cube bet?');">
                @Html.AntiForgeryToken()
                <button type="submit">Cancel bet (refund @cube.Amount)</button>
            </form>
        }
        else
        {
            <p class="muted">No pending bet.</p>
        }
    </div>

    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Darts 🎯</h2>
        @if (Model.Detail.DartsBet is { } darts)
        {
            <p>Pending bet: <strong>@darts.Amount</strong> in chat <code>@darts.ChatId</code></p>
            <form method="post" action="/admin/user/@u.TelegramUserId/darts/cancel"
                  onsubmit="return confirm('Refund @darts.Amount and drop pending darts bet?');">
                @Html.AntiForgeryToken()
                <button type="submit">Cancel bet (refund @darts.Amount)</button>
            </form>
        }
        else
        {
            <p class="muted">No pending bet.</p>
        }
    </div>

    @if (Model.Detail.SecretHitlerPlayer is { } shPlayer && Model.Detail.SecretHitlerGame is { } shGame)
    {
        <div class="card">
            <h2 style="margin-top:0; font-size:16px;">Secret Hitler 🗳</h2>
            <p>
                Room <a href="/admin/sh/@shGame.InviteCode"><code>@shGame.InviteCode</code></a> ·
                seat @shPlayer.Position ·
                role <strong>@shPlayer.Role</strong> ·
                <span class="pill">@shGame.Status / @shGame.Phase</span>
            </p>
            <p class="muted">Host: @shGame.HostUserId · buy-in @shGame.BuyIn · pot @shGame.Pot · alive: @(shPlayer.IsAlive ? "yes" : "no")</p>
        </div>
    }

    <div class="card">
        <h2 style="margin-top:0; font-size:16px;">Blackjack</h2>
        <p>Hands played: <strong>@u.BlackjackHandsPlayed</strong></p>
        @if (Model.Detail.BlackjackHand is { } bj)
        {
            <p>Active hand: bet <strong>@bj.Bet</strong> · player <code>@bj.PlayerCards</code> · dealer <code>@bj.DealerCards</code></p>
            <form method="post" action="/admin/user/@u.TelegramUserId/blackjack/cancel"
                  onsubmit="return confirm('Cancel active hand and refund @bj.Bet coins?');">
                @Html.AntiForgeryToken()
                <button type="submit">Cancel hand (refund @bj.Bet)</button>
            </form>
        }
        else
        {
            <p class="muted">No active hand.</p>
        }
    </div>
}
