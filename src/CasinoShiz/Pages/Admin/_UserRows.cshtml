@model CasinoShiz.Services.Admin.UserListResult

@if (Model.Users.Count == 0)
{
    <tr><td colspan="6" class="muted">No users found.</td></tr>
}
@foreach (var u in Model.Users)
{
    <tr>
        <td><code>@u.TelegramUserId</code></td>
        <td>@u.DisplayName</td>
        <td>@u.Coins</td>
        <td>@u.AttemptCount@(u.ExtraAttempts > 0 ? $" (+{u.ExtraAttempts})" : "")</td>
        <td class="muted">@u.LastDayUtc</td>
        <td><a href="/admin/user/@u.TelegramUserId">Open →</a></td>
    </tr>
}
