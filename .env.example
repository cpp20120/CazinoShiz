# Required
Bot__Token=
Bot__BotUsername=

# Admin access (Telegram user IDs, comma-separated in separate vars)
Bot__Admins__0=
# Bot__ReadOnlyAdmins__0=

# Postgres (overrides appsettings.json for Docker)
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=;Username=;Password=

# Redis — required when Redis:Enabled=true (set in docker-compose env)
 Redis__Enabled=true
Redis__ConnectionString=redis:port

# ClickHouse — required when ClickHouse:Enabled=true
# ClickHouse__Enabled=true
# ClickHouse__Host=http://clickhouse:8123

# Optional
# Bot__TrustedChannel=@yourchannel
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
