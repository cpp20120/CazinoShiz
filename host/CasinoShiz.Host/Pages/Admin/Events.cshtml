@page "/admin/events"
@model CasinoShiz.Host.Pages.Admin.EventsModel
@{ ViewData["Title"] = "Events"; }

<h2>Domain events</h2>

<div class="card">
    <form method="get" class="inline">
        <label>Module:</label>
        <select name="Module" onchange="this.form.submit()">
            <option value="">(all)</option>
            @foreach (var m in Model.Modules)
            {
                if ((Model.Module ?? "") == m) { <option value="@m" selected>@m</option> }
                else { <option value="@m">@m</option> }
            }
        </select>
        <label>Chat (payload <code>ChatId</code>):</label>
        <select name="ChatId" onchange="this.form.submit()">
            <option value="">(all)</option>
            @foreach (var c in Model.Chats)
            {
                if (Model.ChatId == c.ChatId) { <option value="@c.ChatId" selected>@c.Label</option> }
                else { <option value="@c.ChatId">@c.Label</option> }
            }
        </select>
        <a href="/admin/groups" class="muted" style="margin-left:6px" title="Where chat list comes from">chats &amp; groups</a>
        <noscript><button type="submit">Filter</button></noscript>
    </form>
    <p class="muted" style="margin:8px 0 0 0">With a chat selected, only events that include a <code>ChatId</code> in JSON are shown (some modules omit it).</p>
</div>

<div class="card">
    <table>
        <thead>
            <tr>
                <th style="width: 60px">#</th>
                <th>When</th>
                <th>Type</th>
                <th style="width: 60%">Payload</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Rows)
            {
                <tr>
                    <td class="muted">@e.Id</td>
                    <td class="muted">@e.OccurredAt.UtcDateTime.ToString("MM-dd HH:mm:ss")</td>
                    <td><code>@e.EventType</code></td>
                    <td><pre>@e.PayloadJson</pre></td>
                </tr>
            }
            @if (Model.Rows.Count == 0)
            {
                <tr><td colspan="4" class="muted">No events for this filter.</td></tr>
            }
        </tbody>
    </table>
</div>
<p class="muted">Showing up to 200 most recent events.</p>
