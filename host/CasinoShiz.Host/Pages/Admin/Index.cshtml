@page "/admin"
@model CasinoShiz.Host.Pages.Admin.IndexModel
@{ ViewData["Title"] = "Dashboard"; }

<h2>Dashboard</h2>

<div class="cards">
    <div class="stat"><div class="label">People (distinct)</div><div class="value">@Model.PeopleCount</div></div>
    <div class="stat"><div class="label">Wallet rows</div><div class="value">@Model.WalletRowCount</div></div>
    <div class="stat"><div class="label">Total coins (sum)</div><div class="value">@Model.TotalCoins</div></div>
    <div class="stat"><div class="label">Pending bets</div><div class="value">@Model.PendingBets</div></div>
    <div class="stat"><div class="label">Domain events</div><div class="value">@Model.EventCount</div></div>
</div>

<div class="card">
    <h3>Mini-game drop tracking</h3>
    <p class="muted">Plays come from domain events. Drop requests are automatic redeem-code drops; issued/active/redeemed come from <code>redeem_codes</code>.</p>
    <table>
        <thead>
            <tr>
                <th>Game</th>
                <th>Plays</th>
                <th>Drop requests</th>
                <th>Drop rate</th>
                <th>Issued codes</th>
                <th>Active</th>
                <th>Redeemed</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var x in Model.MiniGameDrops)
            {
                <tr>
                    <td><code>@x.GameId</code> @x.Label</td>
                    <td>@x.Plays</td>
                    <td>@x.DropRequests</td>
                    <td>@x.DropRatePercent.ToString("0.##")%</td>
                    <td>@x.IssuedCodes</td>
                    <td>@x.ActiveCodes</td>
                    <td>@x.RedeemedCodes</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card">
    <h3>Modules loaded</h3>
    <table>
        <thead><tr><th>Id</th><th>Name</th><th>Version</th></tr></thead>
        <tbody>
            @foreach (var m in Model.Modules.OrderBy(m => m.Id))
            {
                <tr>
                    <td><code>@m.Id</code></td>
                    <td>@m.DisplayName</td>
                    <td>@m.Version</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card">
    <h3>Events by module</h3>
    @if (Model.EventsByModule.Count == 0)
    {
        <p class="muted">No domain events recorded yet.</p>
    }
    else
    {
        <table>
            <thead><tr><th>Module</th><th>Events</th></tr></thead>
            <tbody>
                @foreach (var x in Model.EventsByModule)
                {
                    <tr><td><code>@x.Module</code></td><td>@x.Count</td></tr>
                }
            </tbody>
        </table>
    }
</div>
